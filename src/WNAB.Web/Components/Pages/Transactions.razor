@page "/transactions"

<PageTitle>Transactions - WNAB</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Transactions</h1>
        <button class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Transaction
        </button>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <div class="row align-items-center">
                        <div class="col">
                            <h5>Transaction History</h5>
                        </div>
                        <div class="col-auto">
                            <div class="input-group">
                                <input type="text" class="form-control" placeholder="Search transactions...">
                                <button class="btn btn-outline-secondary">
                                    <i class="bi bi-search"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="text-center p-4">
                        <i class="bi bi-receipt display-1 text-muted"></i>
                        <h4 class="mt-3">No Transactions Yet</h4>
                        <p class="text-muted">Start tracking your spending by adding transactions manually or connecting your bank accounts.</p>
                        <button class="btn btn-primary btn-lg">
                            <i class="bi bi-plus-circle"></i> Add Your First Transaction
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>