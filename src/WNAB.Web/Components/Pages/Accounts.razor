@page "/accounts"

<PageTitle>Accounts - WNAB</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Accounts</h1>
        <button class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Account
        </button>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5>Your Accounts</h5>
                </div>
                <div class="card-body">
                    <div class="text-center p-4">
                        <i class="bi bi-bank display-1 text-muted"></i>
                        <h4 class="mt-3">No Accounts Yet</h4>
                        <p class="text-muted">Get started by adding your first bank account, credit card, or cash account.</p>
                        <button class="btn btn-primary btn-lg">
                            <i class="bi bi-plus-circle"></i> Add Your First Account
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>